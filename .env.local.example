# ============================================================
# Style Heba - Environment Variables
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (Email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=hello@styleheba.com

# App
NEXT_PUBLIC_APP_URL=https://styleheba.com
NEXT_PUBLIC_APP_NAME=Style Heba

# Payment Info (displayed on checkout)
NEXT_PUBLIC_ZELLE_EMAIL=pay@styleheba.com
NEXT_PUBLIC_VENMO_HANDLE=@styleheba
